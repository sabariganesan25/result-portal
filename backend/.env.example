PORT=5000
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=YOUR_KEY
AWS_SECRET_ACCESS_KEY=YOUR_SECRET
DYNAMODB_TABLE=students-results
JWT_SECRET=aurcc_super_secret_key_2025
JWT_EXPIRES_IN=24h
FRONTEND_URL=http://localhost:5173
SMARTOPS_ENABLED=true
SMARTOPS_POLL_INTERVAL_MS=5000
SMARTOPS_KUBECONFIG=
EKS_CLUSTER_NAME=aurcc-portal-cluster
SMARTOPS_MONITOR_NAMESPACES=default,kube-system
SMARTOPS_FRONTEND_ORIGIN=http://localhost:5173
PROMETHEUS_BASE_URL=http://prometheus-server.monitoring.svc.cluster.local
PROMETHEUS_TIMEOUT_MS=5000
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=smartops-observability
KAFKA_GROUP_ID=smartops-observability-group
KAFKA_SSL=false
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
SMARTOPS_CLOUDWATCH_LOG_GROUPS=/aws/containerinsights/aurcc-portal-cluster/application
SMARTOPS_CLOUDWATCH_LOG_LIMIT=100
SMARTOPS_LOG_LOOKBACK_MS=300000
